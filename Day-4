//Problem --7
//Print hollow square pattern
#include <iostream>
using namespace std;

int main() {
    int m;
    cin>>m;
    // number of times to print pattern
	for(int i=1;i<=m;i++){
	   for(int j=1;j<=m;j++){
	       cout<<" ";
	       if(i==1||j==1||j==m||i==m){
	           cout<<"*";
	       }else{
	           cout<<" ";
	       }
	    }
	    cout<<endl;
	}

}






