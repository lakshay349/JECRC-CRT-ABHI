//Problem --1
//Print 1-10, 10 number of times
#include <bits/stdc++.h>
using namespace std;

int main() {
    // number of times to print patten
	for(int i=1;i<=10;i++){
	    // defines what to print a pattern
	    for(int j=1;j<=10;j++){
	        cout<<j<<" ";
	    }
	    cout<<endl;
	}

}


