//Problem --4
//Print pyramid pattern
#include <bits/stdc++.h>
using namespace std;

int main() {
    int m;
    cin>>m;
    // number of times to print patten
	for(int i=1;i<=m;i++){
	   for(int k=(i-1);k<=m;k++){
	       cout<<" ";
	   }
	    // defines what to print a pattern
	    for(int j=1;j<=i;j++){
	        cout<<"*"<<" ";
	    }
	    cout<<endl;
	}

}



//Problem --5
//Print pyramid pattern
#include <iostream>
using namespace std;

int main() {
    int m;
    cin>>m;
    // number of times to print pattern
	for(int i=1;i<=m;i++){
	   for(int k=m-i;k>=1;k--){
	       cout<<" ";
	   }
	    // defines what to print a pattern
	    for(int j=1;j<=i;j++){
	        cout<<"*";
	    }
	    cout<<endl;
	}

}


