// Problem -- 4
// Print 1-10 using while loop
#include <bits/stdc++.h>
using namespace std;

int main() {
int i=1;
while(i<=10){
    cout<<i<<endl;
    i++;
}
}

// Problem -- 5
// Print 10-1 using while loop
#include <bits/stdc++.h>
using namespace std;

int main() {
int i=10;
while(i>=1){
    cout<<i<<endl;
    i--;
}
}


// Problem -- 6
// Print 1-10 using do-while loop
#include <bits/stdc++.h>
using namespace std;

int main(){
    int i=1;
    do {
        cout<<i<<endl;
        i++;
    }while(i<=10);
    return 0;
}

// Problem -- 7
// Print 10-1 using do-while loop
#include <bits/stdc++.h>
using namespace std;

int main(){
    int i=10;
    do {
        cout<<i<<endl;
        i--;
    }while(i>=1);
    return 0;
}

