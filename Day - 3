// Problem -- 8
// Factorial of any number
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int fact =1;
    for(int i=n;i>=1;i--){
        fact = fact*i;
    }
    cout<<fact;
    return 0;
}


// Problem --9
// Print Fibonacci series
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int c;
    int a=0;
    int b=1;
    
    for(int i = 0; i<n; i++){
        cout<<a<<endl;
        c=a+b;
        a=b;
        b=c;
    }
    return 0;
}


// Problem --10
// Check Prime numbers 
#include<iostream>
using namespace std;
int main(){
    
    int n;
    cin>> n;
    bool isPrime=true;
    
    if(n<2){
        isPrime=false;
    }else{
        for(int i=2;i<n;i++){
            if(n%i==0){
                isPrime = false;
                break;
            }
        }
    }
    if(isPrime){
        cout<<"Prime Number";
    }else{
        cout<<"Not a Prime Number";
    }
    return 0;
        
        
    
}



