// Problem -- 6
// Print 1-10 using do-while loop
#include <bits/stdc++.h>
using namespace std;

int main(){
    int i=1;
    do {
        cout<<i<<endl;
        i++;
    }while(i<=10);
    return 0;
}

// Problem -- 7
// Print 10-1 using do-while loop
#include <bits/stdc++.h>
using namespace std;

int main(){
    int i=10;
    do {
        cout<<i<<endl;
        i--;
    }while(i>=1);
    return 0;
}


// Problem -- 8
// Factorial of any number
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int fact =1;
    for(int i=n;i>=1;i--){
        fact = fact*i;
    }
    cout<<fact;
    return 0;
}


// Problem --9
// Print Fibonacci series
#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int c;
    int a=0;
    int b=1;
    
    for(int i = 0; i<n; i++){
        cout<<a<<endl;
        c=a+b;
        a=b;
        b=c;
    }
    return 0;
}
