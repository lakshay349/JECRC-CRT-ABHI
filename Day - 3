// Problem 1 --
// Print 1-10 using a for loop
#include <bits/stdc++.h>
using namespace std;

int main() {
for(int i = 1; i<=10;i++){
    cout<<i<<endl;
}

}


// Problem 2 --
// Print 10-1 using a for loop
#include <bits/stdc++.h>
using namespace std;

int main() {
for(int i = 10; i>=1;i--){
    cout<<i<<endl;
}

}


