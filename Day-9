// Problem -- 1
// Function Overriding
#include <iostream>
using namespace std;
class Appliance{
    public:
    virtual void TurnOn(){
        cout<<"Appliance is turned on....."<<endl;
    }
    virtual void work()=0;
};
class Fan : public Appliance{
    public:
    void TurnOn() override{
        cout<<"Fan blades are moving slowly..."<<endl;
    }
    void work() override{
        cout<<"Fan is giving out cool air..."<<endl;
    }
};
class Toaster : public Appliance{
    void work() override{
        cout<<"Toater is toasting my bread."<<endl;
    }
};
int main()
{
    Appliance* KitchenApp;
    Fan myfan;
    KitchenApp = &myfan;
    KitchenApp->TurnOn();
    KitchenApp->work();
    
    Toaster myToast;
    KitchenApp = &myToast;
    KitchenApp->TurnOn();
    KitchenApp->work();

    return 0;
}



// Problem --- 2
// Constructor Overloading
#include<iostream>
using namespace std;

class Rectangle{
    public:
    int length;
    int width;
    Rectangle(){
        length=1;
        width=1;
    }
    Rectangle(int side){
        length=side;
        width=side;
    }
    Rectangle(int side1,int side2){
        length=side1;
        width=side2;
    }
    void showArea(){
        cout<<length*width<<endl;
    }
    
};

int main(){
    Rectangle r1;
    Rectangle r2(5);
    Rectangle r3(5,4);
    
    r1.showArea();
    r2.showArea();
    r3.showArea();
}


// Problem -- 3
// Introduction to Arrays + Traversal + Memory Layout
#include<iostream>
using namespace std;
void traversal(int arr[],int size){
    for(int i=0;i<size;i++){
        cout<<arr[i]<<" ";
    }
}


int main(){
    int arr[]={10,20,30,40,50};
    traversal(arr,5);
    return 0;
}


// Problem -- 4
// Print array address of each data
#include<iostream>
using namespace std;
void arrayaddress(int arr[],int size){
    for(int i=0;i<size;i++){
        cout<<&arr[i]<<" ";
    }
}


int main(){
    int arr[]={10,20,30,40,50};
    arrayaddress(arr,5);
    return 0;
}
