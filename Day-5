// Problem --5
// To print a right angle triangle and its inverse
#include<iostream>
using namespace std;
int main()
{
    int n;
    cin>>n;
    for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
            cout<<"*";}
            
        cout<<endl;
    }

            for(int m=n-1;m>=1;m--){
                
            
            for(int k=m;k>=1;k--){
                cout<<"*";
        }
        cout<<endl;        
            }
    return 0;
}


