// 2.2 -- Parameterized Constructors
#include<iostream>
using namespace std;
class Student{
    public:
    string name;
    int id;
    Student(string studentName, int studentID){
        name = studentName;
        id = studentID;
    }
    public:
    void displayDetails(){
        cout<<"Name: "<<name<<endl<<"ID: "<<id;
    }
};
int main(){
    Student std1("Lakshay",1180);
    std1.displayDetails();
}
