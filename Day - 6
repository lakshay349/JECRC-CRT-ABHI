// Problem--1
// Swapping of values of 2 variables using swap function
#include <iostream>
using namespace std;
void swapNumber(int* x, int* y){
    int temp =*x;
    *x = *y;
    *y = temp;
}
int main()
{

       int a;
       int b;
       cin>>a>>b;
       swapNumber(&a,&b);
       cout<<a<<" "<<b;
   

    return 0;
}
