// Practice Problem
// Smart AC Remote / Function overloading / Default Arguments

#include<iostream>
using namespace std;
void setTemperature(int temp =22){
    cout<<"temperature set to "<<temp<<" C"<<endl;
}

void setTemperature(double temp){
    cout<<"temperature set to "<<temp<<" C"<<endl;
}
void setTemperature(string mode){
    if(mode=="ECO"){
        cout<<"temperature set to 24 C "<<endl;
        
    }else if(mode == "TURBO"){
        cout<<"temperature set to 18 C "<<endl;
    }
}
int main(){
    setTemperature(); // default value -- 22
    setTemperature(20.5); // manually setting the temperature
    setTemperature("ECO") ;
     setTemperature("TURBO"); // setTemperature to 18
}



