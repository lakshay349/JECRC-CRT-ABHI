// Types -- 1.3 Hierarchial Inheritance
#include<iostream>
using namespace std;
class vehicle{
    public:
    void start(){
        cout<<"vehicle starts"<<endl;
    }
};

class Bike : public vehicle{
    public:
    void drive(){
        cout<<"Bike is running"<<endl;
    }
};

class Car : public vehicle{
    public:
    void cool(){
        cout<<"car run kar gayi"<<endl;
    }
};
int main(){
    Car obj1;
    Bike obj2;
    
    obj1.start();
    obj1.cool();
    
    obj2.start();
    obj2.drive();
    
    
}



// Multiple Inheritance
#include <iostream>
using namespace std;
class Parent1 {
    public:
   void givememoney(){
        cout<<"mommy give me bucks."<<endl;
    }
};
class Parent2 {
    public:
   void givememoney(){
        cout<<"daddy gimme money."<<endl;
    }
};
class submissive : public Parent1, public Parent2{
    
};
int main()
{
   submissive obj1;
   obj1.Parent1::givememoney();
   obj1.Parent2::givememoney();

    return 0;
}



// Hieraechial Inheritance
#include <iostream>
using namespace std;
class A {
    public:
    void print(){
        cout<<"Modi papa jeet gaye"<<endl;
    }
};
class B : virtual public A {
    // NO LOGIC
};
class C : virtual public A {
    // NO LOGIC
};
class D : public B,public C {
    // NO LOGIC
};
int main(){
    D obj1;
    obj1.print();
}
