// function overriding
#include<iostream>
using namespace std;
class Parent{
    public:
    virtual void sum(int a, int b){
        cout<<"a+b: "<<a+b<<endl;
    }
};
class child : public Parent{
    public:
    void sum(int a,int b) override {
       cout<<"a+b"<<a+b<<endl; 
    }
};
int main (){
    Parent p;
    child c;
    c.sum(10,20);
    p.sum(13,13);
}


